# Copy to .env and fill in. Do NOT commit .env.

# --- Phase 0 ---
# Host port 2345 = shared Postgres container.
DATABASE_URL="postgresql://postgres:postgres@localhost:2345/price_tracker?schema=public"
PORT=3000

# --- Phase 1 (Auth) ---
# Generate strong random values for production, e.g. `openssl rand -hex 32`.
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
# Trial granted at registration (DESIGN.md §14.5).
TRIAL_DURATION_DAYS=30

# --- Phase 3 (Uploads / S3) — not used yet ---
